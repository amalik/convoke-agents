+    validatePluginEntry,
+    auditSkillDirs,
+    validateModuleYaml,
+    checkVersionDrift,
+    MARKETPLACE_REL,
+    MODULE_YAML_REL,
+    EXPECTED_PLUGIN_NAME,
+    EXPECTED_MODULE_CODE,
+    REQUIRED_TOP_FIELDS,
+    REQUIRED_PLUGIN_FIELDS,
+    REQUIRED_MODULE_YAML_FIELDS,
+  }),
+};
+
+if (require.main === module) {
+  process.exit(main(process.argv.slice(2)));
+}

